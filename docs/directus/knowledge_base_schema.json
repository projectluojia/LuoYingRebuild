{
  "collections": [
    {
      "collection": "knowledge_spaces",
      "note": "Knowledge space configuration",
      "fields": [
        {"field": "name", "type": "string", "required": true},
        {"field": "organization", "type": "string"},
        {"field": "description", "type": "text"},
        {"field": "ragflow_dataset_id", "type": "string"},
        {"field": "directus_scope", "type": "string"},
        {"field": "allowed_platforms", "type": "json"},
        {"field": "allowed_conversations", "type": "json"},
        {"field": "enabled", "type": "boolean", "default_value": true}
      ]
    },
    {
      "collection": "kb_sites",
      "note": "Managed website sources",
      "fields": [
        {"field": "site_id", "type": "string", "required": true},
        {"field": "name", "type": "string", "required": true},
        {"field": "base_url", "type": "string", "required": true},
        {"field": "space_id", "type": "string", "required": true},
        {"field": "ragflow_dataset_id", "type": "string"},
        {"field": "allowed_domains", "type": "json"},
        {"field": "entry_urls", "type": "json"},
        {"field": "crawl_config", "type": "json"},
        {"field": "enabled", "type": "boolean", "default_value": true},
        {"field": "last_crawled_at", "type": "datetime"}
      ]
    },
    {
      "collection": "kb_crawl_runs",
      "note": "Website crawl run history",
      "fields": [
        {"field": "site_id", "type": "string", "required": true},
        {"field": "status", "type": "string", "required": true},
        {"field": "started_at", "type": "datetime"},
        {"field": "finished_at", "type": "datetime"},
        {"field": "pages_seen", "type": "integer"},
        {"field": "pages_created", "type": "integer"},
        {"field": "pages_updated", "type": "integer"},
        {"field": "pages_failed", "type": "integer"},
        {"field": "assets_downloaded", "type": "integer"},
        {"field": "error_message", "type": "text"}
      ]
    },
    {
      "collection": "kb_pages",
      "note": "Canonical crawled pages",
      "fields": [
        {"field": "site_id", "type": "string", "required": true},
        {"field": "space_id", "type": "string", "required": true},
        {"field": "canonical_url", "type": "string", "required": true},
        {"field": "title", "type": "string"},
        {"field": "published_at", "type": "datetime"},
        {"field": "content_hash", "type": "string"},
        {"field": "status", "type": "string"},
        {"field": "ragflow_document_id", "type": "string"},
        {"field": "ragflow_sync_status", "type": "string"},
        {"field": "extract_status", "type": "string"},
        {"field": "last_crawled_at", "type": "datetime"},
        {"field": "last_crawl_run", "type": "string"}
      ]
    },
    {
      "collection": "kb_page_versions",
      "note": "Versioned page text and RAGFlow sync references",
      "fields": [
        {"field": "page_id", "type": "string", "required": true},
        {"field": "content_hash", "type": "string", "required": true},
        {"field": "raw_html", "type": "text"},
        {"field": "clean_text", "type": "text"},
        {"field": "ragflow_document_id", "type": "string"},
        {"field": "ragflow_sync_status", "type": "string"},
        {"field": "created_at", "type": "datetime"}
      ]
    },
    {
      "collection": "admission_scores",
      "note": "Structured admission score records",
      "fields": [
        {"field": "space_id", "type": "string", "required": true},
        {"field": "year", "type": "integer"},
        {"field": "province", "type": "string"},
        {"field": "subject_type", "type": "string"},
        {"field": "batch", "type": "string"},
        {"field": "major_name", "type": "string"},
        {"field": "class_type", "type": "string"},
        {"field": "max_score", "type": "float"},
        {"field": "min_score", "type": "float"},
        {"field": "avg_score", "type": "float"},
        {"field": "min_rank", "type": "integer"},
        {"field": "enrollment_count", "type": "integer"},
        {"field": "source_url", "type": "string"},
        {"field": "source_document", "type": "string"},
        {"field": "source_text", "type": "text"},
        {"field": "review_status", "type": "string", "default_value": "pending"},
        {"field": "note", "type": "text"}
      ]
    },
    {
      "collection": "admission_plans",
      "note": "Structured admission plan records",
      "fields": [
        {"field": "space_id", "type": "string", "required": true},
        {"field": "year", "type": "integer"},
        {"field": "province", "type": "string"},
        {"field": "subject_type", "type": "string"},
        {"field": "batch", "type": "string"},
        {"field": "major_name", "type": "string"},
        {"field": "class_type", "type": "string"},
        {"field": "planned_count", "type": "integer"},
        {"field": "tuition", "type": "float"},
        {"field": "duration_years", "type": "integer"},
        {"field": "source_url", "type": "string"},
        {"field": "source_document", "type": "string"},
        {"field": "source_text", "type": "text"},
        {"field": "review_status", "type": "string", "default_value": "pending"},
        {"field": "note", "type": "text"}
      ]
    },
    {
      "collection": "majors",
      "note": "Structured major records",
      "fields": [
        {"field": "space_id", "type": "string", "required": true},
        {"field": "name", "type": "string", "required": true},
        {"field": "aliases", "type": "json"},
        {"field": "degree", "type": "string"},
        {"field": "category", "type": "string"},
        {"field": "description", "type": "text"},
        {"field": "core_courses", "type": "text"},
        {"field": "training_goals", "type": "text"},
        {"field": "suitable_students", "type": "text"},
        {"field": "career_directions", "type": "text"},
        {"field": "further_study_directions", "type": "text"},
        {"field": "source_url", "type": "string"},
        {"field": "source_document", "type": "string"},
        {"field": "review_status", "type": "string", "default_value": "pending"}
      ]
    },
    {
      "collection": "class_types",
      "note": "Class type records",
      "fields": [
        {"field": "space_id", "type": "string", "required": true},
        {"field": "name", "type": "string", "required": true},
        {"field": "aliases", "type": "json"},
        {"field": "description", "type": "text"},
        {"field": "selection_method", "type": "text"},
        {"field": "training_mode", "type": "text"},
        {"field": "enrollment_rule", "type": "text"},
        {"field": "source_url", "type": "string"},
        {"field": "source_document", "type": "string"},
        {"field": "review_status", "type": "string", "default_value": "pending"}
      ]
    },
    {
      "collection": "dynamic_qa",
      "note": "Reviewed dynamic Q&A records",
      "fields": [
        {"field": "space_id", "type": "string", "required": true},
        {"field": "question", "type": "text", "required": true},
        {"field": "answer", "type": "text", "required": true},
        {"field": "similar_questions", "type": "json"},
        {"field": "submitted_by", "type": "string"},
        {"field": "reviewed_by", "type": "string"},
        {"field": "review_status", "type": "string", "default_value": "pending"},
        {"field": "ragflow_synced", "type": "boolean", "default_value": false},
        {"field": "metadata", "type": "json"},
        {"field": "created_at", "type": "datetime"}
      ]
    },
    {
      "collection": "kb_answer_logs",
      "note": "Knowledge answer logs",
      "fields": [
        {"field": "request_uid", "type": "string"},
        {"field": "space_id", "type": "string"},
        {"field": "platform", "type": "string"},
        {"field": "conversation_id", "type": "string"},
        {"field": "user_id", "type": "string"},
        {"field": "question", "type": "text"},
        {"field": "extracted_slots", "type": "json"},
        {"field": "directus_results", "type": "json"},
        {"field": "ragflow_results", "type": "json"},
        {"field": "citations", "type": "json"},
        {"field": "answer", "type": "text"},
        {"field": "confidence", "type": "float"},
        {"field": "fallback_reason", "type": "string"},
        {"field": "created_at", "type": "datetime"}
      ]
    },
    {
      "collection": "kb_feedback",
      "note": "Knowledge answer feedback",
      "fields": [
        {"field": "answer_log_id", "type": "string"},
        {"field": "request_uid", "type": "string"},
        {"field": "feedback_type", "type": "string", "required": true},
        {"field": "comment", "type": "text"},
        {"field": "submitted_by", "type": "string"},
        {"field": "status", "type": "string"},
        {"field": "handled_by", "type": "string"},
        {"field": "handled_at", "type": "datetime"},
        {"field": "created_at", "type": "datetime"}
      ]
    }
  ]
}

