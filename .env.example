# Local knowledge base. Markdown artifacts are committed; Postgres/pgvector is runtime state.
KB_ARTIFACT_ROOT=./knowledge
KB_DATABASE_URL=postgresql://luoying_kb:luoying_kb@127.0.0.1:15432/luoying_kb
KB_DEFAULT_SPACE_ID=sai
KB_REQUIRE_CITATION=true
# Min cosine similarity the best retrieved chunk must reach for chunk-only answers;
# below this the policy refuses (low_relevance) instead of answering from weak matches.
# Only applies when no structured (analytics) records were found. Set to 0 to disable.
KB_MIN_RELEVANCE=0.5
KB_EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
KB_EMBEDDING_API_KEY=
KB_EMBEDDING_MODEL=text-embeddings-inference
KB_EMBEDDING_BATCH_SIZE=32
KB_EMBEDDING_DIMENSIONS=512

MEMORY_MAX_MESSAGES_PER_THREAD=80
AGENT_SKILL_TIMEOUT_SEC=360
AGENT_TOTAL_TIMEOUT_SEC=6000
MAX_CONCURRENT_MESSAGE_TASKS=200
